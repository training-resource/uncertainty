{
  "name": "RStudio Codespace",
  // Use a Rocker image with RStudio Server built-in
  "image": "ghcr.io/rocker-org/devcontainer/tidyverse:4.3",

  // Configuration to forward the RStudio port (8787)
  "forwardPorts": [8787],

  // Command to run after the container is created to ensure RStudio starts and opens
  "postCreateCommand": "bash .devcontainer/welcome.sh",

  // Customization to automatically open the RStudio URL
  "customizations": {
    "codespaces": {
      "openFiles": [] // No files to open in VS Code interface, RStudio will open separately
    }
  }
}